# Copy to .env and fill in real secrets. Do not commit .env.

# Required when using the default DeepSeek model.
DEEPSEEK_API_KEY=

# Model passed to opencode as provider/model.
# Default in src/core.ts: deepseek/deepseek-v4-flash
SWARM_MODEL=deepseek/deepseek-v4-flash
# Variants are chosen by role: orchestrator/fixer use max, reviewers use low.

# Agent type passed to opencode.
SWARM_AGENT=build

# Run limits and polling behavior.
SWARM_MAX_ITERATIONS=3
SWARM_AGENT_TIMEOUT_MS=900000
SWARM_WAIT_LOG_INTERVAL_MS=10000

# Port for the browser UI (npm run swarm:web). Defaults to 5180.
SWARM_WEB_PORT=5180

# Optional: override only selected roles.
# SWARM_ORCHESTRATOR_MODEL=deepseek/deepseek-v4-flash
# SWARM_FIXER_MODEL=deepseek/deepseek-v4-flash

# Optional: connect to an already-running opencode server instead of spawning one.
# If set, make sure that server process already has provider API keys in its environment.
# SWARM_OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Optional: use opencode.ai Zen/free models instead of a provider key.
# OPENCODE_API_KEY=
# SWARM_MODEL=opencode/deepseek-v4-flash-free
