# Langfuse observability (https://langfuse.com)
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://jp.cloud.langfuse.com"  # or https://cloud.langfuse.com for US/EU

# DeepSeek API key — required for default SWARM_MODEL=deepseek/deepseek-v4-flash
DEEPSEEK_API_KEY="sk-..."

# Global model for all agents (default: deepseek/deepseek-v4-flash, variant: auto)
# SWARM_MODEL=deepseek/deepseek-v4-flash
# SWARM_VARIANT=max

# Fixer-agent model override — defaults to deepseek/deepseek-v4-pro + max even when
# SWARM_MODEL points to a cheaper model, because the fixer does multi-file edits.
SWARM_FIXER_MODEL=deepseek/deepseek-v4-pro
SWARM_FIXER_VARIANT=max
