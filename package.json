{
  "name": "tiny-rewrite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:core": "npm run build && node --test test/core.test.mjs",
    "swarm": "npm run build && node dist/index.js",
    "swarm:tui": "npm run build && cargo run --quiet --manifest-path tui/Cargo.toml --",
    "tiny": "npm run build && node dist/index.js",
    "setup:browsers": "playwright install chromium",
    "setup:browsers:linux": "playwright install --with-deps chromium",
    "test:tui": "cargo test --manifest-path tui/Cargo.toml",
    "test:mock": "npm run build && node test/mock-harness.mjs"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@opencode-ai/sdk": "^1.15.4",
    "opencode-ai": "^1.15.7",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
